#!/bin/bash
# Launch a master/orchestrator Claude Code session with spec-driven-dev workflow.
#
# Source-file guard is enforced by a PreToolUse hook (source-guard-hook.sh),
# not --disallowedTools (which cascades to subagents and blocks them too).
#
# Lifecycle:
#   1. sdd-master creates an empty marker file, exports its path
#   2. Hook's first Edit/Write captures session_id → appends to .master-sessions
#      and writes session_id into the marker file
#   3. On exit, sdd-master reads the marker to deregister from .master-sessions
#
# Multiple concurrent sdd-master sessions each get their own marker and
# register independently. Subagents don't match any registered session_id
# so the hook lets them through.

set -euo pipefail

# --- Model probing ---
CACHE_FILE="$HOME/.cache/sdd/master-model"
if [ -r "$CACHE_FILE" ]; then
  MODEL=$(cat "$CACHE_FILE")
else
  MODEL="claude-opus-4-7[1m]"
  timeout 10 claude --model "$MODEL" -p "probe" --max-turns 0 </dev/null &>/dev/null || MODEL="opus"
  mkdir -p "$(dirname "$CACHE_FILE")"
  printf '%s' "$MODEL" > "$CACHE_FILE"
fi

# --- Master session registration ---
mkdir -p .agent
MASTER_SESSIONS=".agent/.master-sessions"
MARKER=$(mktemp ".agent/.sdd-marker.XXXXXX")
export SDD_MARKER_FILE="$MARKER"

cleanup() {
  local sid
  sid=$(cat "$MARKER" 2>/dev/null || true)
  if [ -n "$sid" ]; then
    grep -vF "$sid" "$MASTER_SESSIONS" > "$MASTER_SESSIONS.tmp" 2>/dev/null || true
    mv -f "$MASTER_SESSIONS.tmp" "$MASTER_SESSIONS" 2>/dev/null || true
  fi
  rm -f "$MARKER"
}
trap cleanup EXIT

# --- Launch claude (foreground, not exec — need trap to fire) ---
claude \
  --model "$MODEL" \
  "$@"
